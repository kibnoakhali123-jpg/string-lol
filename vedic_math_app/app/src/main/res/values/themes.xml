<resources>
    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">#FF99CC</item>
        <item name="colorPrimaryDark">#CC7AA3</item>
        <item name="colorAccent">#FF99CC</item>
    </style>

    <!-- Add this new theme -->
    <style name="Theme.WebToApp" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">#FF99CC</item>
        <item name="colorPrimaryDark">#CC7AA3</item>
        <item name="colorAccent">#FF99CC</item>
        <item name="android:windowBackground">#0B0B0B</item>
        <item name="android:textColor">#F0F0F0</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:statusBarColor">#000000</item>
        <item name="android:navigationBarColor">#000000</item>
    </style>
</resources>